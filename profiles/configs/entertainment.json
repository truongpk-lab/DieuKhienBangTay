{
  "id": "entertainment",
  "name": "Giải trí",
  "description": "Điều khiển phát nội dung, chuyển video và âm lượng.",
  "mouse": {
    "speed": 1.2,
    "sensitivity": 70,
    "smoothing": 3
  },
  "gesture_filter": {
    "hand": "auto",
    "min_confidence": 0.72,
    "debounce_ms": 100
  },
  "functions": [
    {
      "id": "play_pause",
      "label": "Phát / Tạm dừng",
      "gesture_event": "open_close_palm",
      "gesture": "Mở/đóng bàn tay",
      "action": "media.play_pause",
      "enabled": true,
      "payload": {
        "shortcut": "space"
      }
    },
    {
      "id": "next_video",
      "label": "Video tiếp theo",
      "gesture_event": "swipe_right",
      "gesture": "Vuốt phải",
      "action": "media.next",
      "enabled": true,
      "payload": {
        "shortcut": "media_next"
      }
    },
    {
      "id": "previous_video",
      "label": "Video trước",
      "gesture_event": "swipe_left",
      "gesture": "Vuốt trái",
      "action": "media.previous",
      "enabled": true,
      "payload": {
        "shortcut": "media_previous"
      }
    },
    {
      "id": "seek_forward",
      "label": "Tua tới",
      "gesture_event": "two_finger_swipe_right",
      "gesture": "Vuốt hai ngón sang phải",
      "action": "media.seek_forward",
      "enabled": true,
      "payload": {
        "shortcut": "right",
        "seconds": 10
      }
    },
    {
      "id": "seek_backward",
      "label": "Tua lùi",
      "gesture_event": "two_finger_swipe_left",
      "gesture": "Vuốt hai ngón sang trái",
      "action": "media.seek_backward",
      "enabled": true,
      "payload": {
        "shortcut": "left",
        "seconds": 10
      }
    },
    {
      "id": "volume_up",
      "label": "Tăng âm lượng",
      "gesture_event": "swipe_up",
      "gesture": "Vuốt lên",
      "action": "media.volume_up",
      "enabled": true,
      "payload": {
        "shortcut": "volume_up"
      }
    },
    {
      "id": "volume_down",
      "label": "Giảm âm lượng",
      "gesture_event": "swipe_down",
      "gesture": "Vuốt xuống",
      "action": "media.volume_down",
      "enabled": true,
      "payload": {
        "shortcut": "volume_down"
      }
    },
    {
      "id": "fullscreen",
      "label": "Toàn màn hình",
      "gesture_event": "open_palm_hold",
      "gesture": "Giữ bàn tay mở",
      "action": "media.fullscreen",
      "enabled": true,
      "payload": {
        "shortcut": "f"
      }
    },
    {
      "id": "mute",
      "label": "Tắt / bật tiếng",
      "gesture_event": "thumbs_up_mute",
      "gesture": "Giơ ngón cái để bật/tắt",
      "action": "keyboard.hotkey",
      "enabled": true,
      "payload": {
        "shortcut": "m"
      }
    },
    {
      "id": "mini_player",
      "label": "Trình phát thu nhỏ",
      "gesture_event": "two_finger_pose_mini",
      "gesture": "Giữ hai ngón",
      "action": "keyboard.hotkey",
      "enabled": true,
      "payload": {
        "shortcut": "i"
      }
    },
    {
      "id": "captions",
      "label": "Phụ đề",
      "gesture_event": "three_finger_pose_captions",
      "gesture": "Giữ ba ngón",
      "action": "keyboard.hotkey",
      "enabled": true,
      "payload": {
        "shortcut": "c"
      }
    },
    {
      "id": "speed_up",
      "label": "Tăng tốc độ phát",
      "gesture_event": "pinch_move_right_speed",
      "gesture": "Kẹp rồi di chuyển sang phải",
      "action": "keyboard.hotkey",
      "enabled": true,
      "payload": {
        "shortcut": "shift+."
      }
    },
    {
      "id": "speed_down",
      "label": "Giảm tốc độ phát",
      "gesture_event": "pinch_move_left_speed",
      "gesture": "Kẹp rồi di chuyển sang trái",
      "action": "keyboard.hotkey",
      "enabled": true,
      "payload": {
        "shortcut": "shift+,"
      }
    },
    {
      "id": "next_frame",
      "label": "Khung hình kế tiếp",
      "gesture_event": "finger_pose_next_frame",
      "gesture": "Giữ ngón để tới khung kế tiếp",
      "action": "keyboard.hotkey",
      "enabled": true,
      "payload": {
        "shortcut": "."
      }
    },
    {
      "id": "previous_frame",
      "label": "Khung hình trước",
      "gesture_event": "finger_pose_previous_frame",
      "gesture": "Giữ ngón để lùi khung",
      "action": "keyboard.hotkey",
      "enabled": true,
      "payload": {
        "shortcut": ","
      }
    }
  ]
}
